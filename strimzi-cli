#!/bin/bash

# Strimzi CLI Client Script
# This script runs CLI commands that connect to a running Strimzi server

set -e

# Default configuration
JAVA_OPTS="${JAVA_OPTS:--Xms128m -Xmx512m}"
JAR_PATH="target/quarkus-app/quarkus-run.jar"
SERVER_URL="${STRIMZI_SERVER_URL:-http://localhost:8080}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
log_info() {
    echo -e "${BLUE}ℹ️  $1${NC}"
}

log_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

log_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

log_error() {
    echo -e "${RED}❌ $1${NC}"
}

# Check if jar exists
if [ ! -f "$JAR_PATH" ]; then
    log_warning "Application not built. Building now..."
    if ! mvn clean package -DskipTests; then
        log_error "Build failed!"
        exit 1
    fi
    log_success "Build completed"
fi

# Run CLI mode using the main JAR
log_info "Connecting to server: $SERVER_URL"
exec java $JAVA_OPTS -jar "$JAR_PATH" --cli --server="$SERVER_URL" "$@"